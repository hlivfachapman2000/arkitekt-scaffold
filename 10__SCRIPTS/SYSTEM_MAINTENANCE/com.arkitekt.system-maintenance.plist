<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.arkitekt.system-maintenance</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__SCRIPT_PATH__/UPDATE_ALL.sh</string>
    </array>

    <!-- Run every Sunday at 3:00 AM -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>7</integer>
        <key>Hour</key>
        <integer>3</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Run on wake from sleep (optional) -->
    <key>RunAtLoad</key>
    <false/>

    <!-- Standard output/error logging -->
    <key>StandardOutPath</key>
    <string>__SCRIPT_PATH__/logs/launchd_out.log</string>
    <key>StandardErrorPath</key>
    <string>__SCRIPT_PATH__/logs/launchd_err.log</string>

    <!-- Don't run if already running -->
    <key>ThrottleInterval</key>
    <integer>3600</integer>
</dict>
</plist>

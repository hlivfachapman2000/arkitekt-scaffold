# ═══════════════════════════════════════════════════════════════
# ENVIRONMENT: DEVELOPMENT
# Sourced AFTER .env — these values override the base config.
# Use this for dev-machine-specific tweaks: local ports, debug flags, etc.
# ═══════════════════════════════════════════════════════════════

ARKITEKT_ENVIRONMENT=development

# Local overrides
QDRANT_URL=http://localhost:6333
SQLITE_DB_PATH=07__MEMORY_SYSTEM/SQLITE/agent_state.db

# Dev-specific flags
DEBUG=true
LOG_LEVEL=debug
AGENT_LOG_VERBOSITY=verbose

# Local LLM endpoints (Ollama, LM Studio, etc.)
# LOCAL_MODEL_ENDPOINT=http://localhost:11434
# LOCAL_MODEL_NAME=llama3.1

# Disable expensive ops in dev
SKIP_COST_TRACKING=false
SKIP_MEMORY_SYNC=false
